{
  "name": "podcast-annotations",
  "version": "0.2.0",
  "description": "Timed annotation overlays, live transcript sync, chapter sync, and annotation timelines for audio players",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "podcast",
    "annotations",
    "transcript",
    "chapters",
    "audio",
    "player",
    "sync",
    "overlay",
    "timeline",
    "webvtt",
    "vtt",
    "srt"
  ],
  "author": "Ryan Williams",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ryanwi/podcast-annotations-js.git"
  },
  "devDependencies": {
    "jsdom": "^26.1.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.1"
  }
}
